includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - app
        - database
        - routes

    # Level 5 is a sensible, productive baseline for a fresh Laravel app.
    # We can ratchet this up toward 8 as the codebase matures.
    level: 5

    reportUnmatchedIgnoredErrors: false

    ignoreErrors:
        # medialibrary's fluent media-conversion chain (->width()->format()
        # ->nonQueued()) is resolved via __call; Larastan mis-infers it as an
        # ImageDriver. These calls are valid on Spatie\MediaLibrary Conversion.
        - identifier: method.notFound
          message: '#Call to an undefined method Spatie\\Image\\Drivers\\ImageDriver::#'
